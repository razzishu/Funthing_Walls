<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#121212"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome to Funthing Walls"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="To keep this app free and ad-free, you need to provide your own Pexels API Key."
        android:textColor="#AAAAAA"
        android:textSize="16sp"
        android:textAlignment="center"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnGetApiKey"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="1. Get Free API Key Here"
        android:backgroundTint="#03DAC5"
        android:textColor="#000000"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/inputApiKey"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="2. Paste API Key Here"
        android:textColorHint="#777777"
        android:textColor="#FFFFFF"
        android:background="@android:drawable/editbox_background_normal"
        android:padding="16dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnUnlockApp"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="3. Unlock App"
        android:backgroundTint="#6200EE"
        android:textColor="#FFFFFF"/>

</LinearLayout>