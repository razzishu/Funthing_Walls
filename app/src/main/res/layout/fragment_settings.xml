<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="?attr/colorOnSurface"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pexels API Key"
            android:textColor="?attr/colorPrimary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/editApiKey"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="?attr/colorSurfaceVariant"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textColorHint="?attr/colorOutline"
            android:padding="16dp"
            android:hint="Paste new API key here"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnSaveApiKey"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Update API Key"
            android:backgroundTint="?attr/colorPrimary"
            android:textColor="?attr/colorOnPrimary"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Auto-Change Background Timer"
            android:textColor="?attr/colorPrimary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <RadioGroup
            android:id="@+id/timerRadioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rb1Hour"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Every 1 Hour"
                android:textColor="?attr/colorOnSurface"
                android:buttonTint="?attr/colorPrimary"
                android:padding="12dp"/>

            <RadioButton
                android:id="@+id/rb6Hours"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Every 6 Hours"
                android:textColor="?attr/colorOnSurface"
                android:buttonTint="?attr/colorPrimary"
                android:padding="12dp"/>

            <RadioButton
                android:id="@+id/rb24Hours"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Every 24 Hours"
                android:textColor="?attr/colorOnSurface"
                android:buttonTint="?attr/colorPrimary"
                android:padding="12dp"/>
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Visual Effects"
            android:textColor="?attr/colorPrimary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp"/>

        <Switch
            android:id="@+id/switchBlurHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Blur Home Screen Wallpaper"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp"
            android:thumbTint="?attr/colorPrimary"
            android:trackTint="?attr/colorSurfaceVariant"
            android:padding="12dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutlineVariant"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="About &amp; Features"
            android:textColor="?attr/colorPrimary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/floating_pill_bg"
            android:padding="16dp"
            android:layout_marginBottom="24dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Version 1.0 (Initial Release)"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• Smart Center-Crop Algorithm\n• True Material You Dynamic Colors\n• Live Video Wallpaper Engine\n• Infinite Curated Galleries\n• Background Auto-Changer\n• Open Source Architecture"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnGithub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="12dp"
            android:gravity="center_vertical">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="GitHub Repository"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@razzishu"
                android:textColor="?attr/colorPrimary"
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnTelegram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Developer Contact"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@Razz_ishu"
                android:textColor="?attr/colorPrimary"
                android:textSize="14sp"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Funthing Walls • Designed with ❤️"
            android:textColor="?attr/colorOutline"
            android:textSize="12sp"
            android:textAlignment="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>
</ScrollView>