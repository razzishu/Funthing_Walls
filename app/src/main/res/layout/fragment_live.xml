<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/searchVideo"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:hint="Search live (e.g., Rain)"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOutline"
            android:background="@drawable/floating_pill_bg"
            android:padding="16dp"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnSearchVideo"
            android:layout_width="wrap_content"
            android:layout_height="60dp"
            android:text="Search"
            android:backgroundTint="?attr/colorPrimary"
            android:textColor="?attr/colorOnPrimary" />
    </LinearLayout>

    <Button
        android:id="@+id/btnPickLocalVideo"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Pick Local Video from Gallery"
        android:backgroundTint="?attr/colorSurfaceVariant"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginBottom="16dp"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/videoRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false" />

        <VideoView
            android:id="@+id/videoPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:visibility="gone"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="?attr/colorPrimary"
            android:visibility="gone"/>
    </FrameLayout>

    <Button
        android:id="@+id/btnApplyLive"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Set as Live Wallpaper"
        android:backgroundTint="?attr/colorPrimary"
        android:textColor="?attr/colorOnPrimary"
        android:layout_marginTop="16dp"
        android:visibility="gone"/>

</LinearLayout>